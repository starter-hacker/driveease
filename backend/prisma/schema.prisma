// FILE: backend/prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  STAFF
  CUSTOMER
}

enum LoyaltyTier {
  BRONZE
  SILVER
  GOLD
  PLATINUM
}

enum CarCategory {
  ECONOMY
  COMPACT
  SUV
  LUXURY
  VAN
  ELECTRIC
}

enum Transmission {
  AUTO
  MANUAL
}

enum FuelType {
  PETROL
  DIESEL
  ELECTRIC
  HYBRID
}

enum CarStatus {
  AVAILABLE
  RENTED
  MAINTENANCE
  RETIRED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  ACTIVE
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  UNPAID
  PAID
  REFUNDED
}

enum PaymentMethod {
  CASH
  CARD
  TRANSFER
}

enum TransactionStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum NotificationType {
  INFO
  SUCCESS
  WARNING
  ERROR
}

model User {
  id             String      @id @default(cuid())
  email          String      @unique
  password       String
  firstName      String
  lastName       String
  phone          String?
  avatar         String?
  role           Role        @default(CUSTOMER)
  driverLicense  String?
  dateOfBirth    DateTime?
  loyaltyTier    LoyaltyTier @default(BRONZE)
  isActive       Boolean     @default(true)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  bookings       Booking[]
  refreshTokens  RefreshToken[]
  notifications  Notification[]

  @@map("users")
}

model Car {
  id           String       @id @default(cuid())
  make         String
  model        String
  year         Int
  category     CarCategory
  pricePerDay  Decimal      @db.Decimal(10, 2)
  pricePerWeek Decimal      @db.Decimal(10, 2)
  seats        Int
  transmission Transmission
  fuelType     FuelType
  mileage      Int          @default(0)
  color        String
  images       String[]
  status       CarStatus    @default(AVAILABLE)
  features     String[]
  rating       Decimal      @default(0) @db.Decimal(3, 2)
  reviewCount  Int          @default(0)
  licensePlate String       @unique
  vin          String       @unique
  description  String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  bookings     Booking[]

  @@map("cars")
}

model Booking {
  id                   String        @id @default(cuid())
  userId               String
  carId                String
  pickupDate           DateTime
  returnDate           DateTime
  pickupLocation       String
  returnLocation       String
  totalDays            Int
  dailyRate            Decimal       @db.Decimal(10, 2)
  insuranceIncluded    Boolean       @default(false)
  gpsIncluded          Boolean       @default(false)
  childSeatIncluded    Boolean       @default(false)
  insuranceCost        Decimal       @default(0) @db.Decimal(10, 2)
  gpsCost              Decimal       @default(0) @db.Decimal(10, 2)
  childSeatCost        Decimal       @default(0) @db.Decimal(10, 2)
  subtotal             Decimal       @db.Decimal(10, 2)
  discount             Decimal       @default(0) @db.Decimal(10, 2)
  totalAmount          Decimal       @db.Decimal(10, 2)
  status               BookingStatus @default(PENDING)
  paymentStatus        PaymentStatus @default(UNPAID)
  paymentReference     String?
  cancellationReason   String?
  notes                String?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  user                 User          @relation(fields: [userId], references: [id])
  car                  Car           @relation(fields: [carId], references: [id])
  payments             Payment[]

  @@map("bookings")
}

model Payment {
  id        String            @id @default(cuid())
  bookingId String
  amount    Decimal           @db.Decimal(10, 2)
  method    PaymentMethod
  status    TransactionStatus @default(PENDING)
  reference String?
  paidAt    DateTime?
  createdAt DateTime          @default(now())

  booking   Booking           @relation(fields: [bookingId], references: [id])

  @@map("payments")
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  title     String
  message   String
  type      NotificationType @default(INFO)
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}